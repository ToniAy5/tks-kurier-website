# IONOS SMTP (https://www.ionos.de/hilfe/e-mail/allgemeine-themen/einrichtung-ihres-ionos-e-mail-kontos-in-einem-mail-programm-ueber-imap-pop3/)
SMTP_HOST=smtp.ionos.de
SMTP_PORT=465
SMTP_USER=noreply@tks-kurierservice.de
SMTP_PASS=dein-noreply-postfach-passwort
MAIL_FROM=TKS Kurier-Service <noreply@tks-kurierservice.de>
MAIL_TO=info@tks-kurierservice.de

# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxx
# Site key wird zusätzlich in script.js eingetragen (öffentlich)
